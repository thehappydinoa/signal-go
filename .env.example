# Copy to .env and adjust paths for your machine:
#   cp .env.example .env
#
# Task (`task build`, `task libsignal`, …) loads .env automatically.
# For plain `go` / `bash` in a shell, run once per session:
#   set -a && source .env && set +a
# or: source scripts/dev-env.sh
#
# CI reference: .github/workflows/ci.yml (Linux) and
# .github/workflows/release.yml (Windows/macOS matrix).

# Required for every cgo build (Taskfile also sets this).
CGO_ENABLED=1

# --- Windows (Git Bash / MSYS2) — mirror release.yml Windows leg ---
# MSYS2 MinGW-w64 must be installed (pacman: mingw-w64-x86_64-gcc, nasm).
# scripts/dev-env.sh prepends mingw64/bin to PATH when it finds gcc.exe.

# Writable temp dir — Rust/cargo and dlltool use Windows TEMP; C:\WINDOWS
# often fails without admin. Use your profile Temp or repo-local .build/tmp.
TMP=C:/Users/YOU/AppData/Local/Temp
TEMP=C:/Users/YOU/AppData/Local/Temp

# cgo must use MinGW gcc (same toolchain that built libsignal_ffi.a), not MSVC.
# Prefer omitting CC/CXX and let scripts/dev-env.sh prepend MSYS2 mingw64/bin to
# PATH. If you set them, use bare names only (gcc / g++), not /c/msys64/... paths.
# CC=gcc
# CXX=g++

# Optional extra link flags when linking tests/binaries against libsignal_ffi.a.
# CGO_LDFLAGS=-lstdc++

# prost-build (libsignal's spqr crate) needs protoc + google/protobuf includes.
# PROTOC=C:/path/to/protoc.exe
# PROTOC_INCLUDE=C:/path/to/protobuf/include

# libsignal Rust build on Windows targets MinGW-gnu (see scripts/build-libsignal.sh).
# CARGO_TARGET=x86_64-pc-windows-gnu

# Pin matches scripts/build-libsignal.sh (Taskfile default).
# LIBSIGNAL_VERSION=v0.94.1

# Force rebuild of libsignal_ffi.a even when the stamp matches.
# FORCE=1
