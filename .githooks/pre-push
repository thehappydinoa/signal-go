#!/usr/bin/env bash
# pre-push: runs vet, lint, and tests before any push.
#
# Install once per clone:
#   git config core.hooksPath .githooks
# or:
#   task hooks:install
#
# The checks require libsignal_ffi.a. If it is not built yet, the hook
# warns and exits without blocking the push — run `task libsignal` once
# to build it, after which all subsequent pushes will be checked.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/dev-env.sh
source "$repo_root/scripts/dev-env.sh"

LIB="internal/libsignal/lib/libsignal_ffi.a"

if [[ ! -f "$LIB" ]]; then
  echo "pre-push: libsignal_ffi.a not found — skipping checks." >&2
  echo "  Run 'task libsignal' to build it. Checks will run on the next push." >&2
  exit 0
fi

echo "pre-push: go vet..."
go vet ./... || { echo "pre-push: go vet failed" >&2; exit 1; }

echo "pre-push: golangci-lint..."
golangci-lint run ./... || { echo "pre-push: lint failed" >&2; exit 1; }

goos="$(go env GOOS)"
race_flag="-race"
if [[ "$goos" == "windows" ]]; then
  # ThreadSanitizer runtime cannot reliably allocate shadow memory on
  # windows/amd64 in this setup (error code 87), so run non-race tests.
  race_flag=""
fi

if [[ -n "$race_flag" ]]; then
  echo "pre-push: go test $race_flag..."
  go test "$race_flag" -count=1 ./... || { echo "pre-push: tests failed" >&2; exit 1; }
else
  echo "pre-push: go test (race disabled on $goos)..."
  go test -count=1 ./... || { echo "pre-push: tests failed" >&2; exit 1; }
fi

echo "pre-push: all checks passed."
